PORT=3000
MONGODB_URI=mongodb://localhost:27017/reconciliation-engine

# ── Matching Tolerances ──────────────────────────────────────────────────────
# Transactions within BOTH windows are considered MATCHED
TIMESTAMP_TOLERANCE_SECONDS=300
QUANTITY_TOLERANCE_PCT=0.0001

# ── Conflict Windows ─────────────────────────────────────────────────────────
# Transactions outside match tolerance but inside conflict window → CONFLICTING
# Transactions outside conflict window → UNMATCHED
CONFLICT_WINDOW_SECONDS=86400
CONFLICT_WINDOW_QTY_PCT=0.5

# ── Data File Paths (optional overrides) ─────────────────────────────────────
# USER_CSV_PATH=./data/user_transactions.csv
# EXCHANGE_CSV_PATH=./data/exchange_transactions.csv
